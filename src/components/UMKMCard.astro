---
import type { GroupData, UmkmData } from '../data/types';
import { photoUrl } from '../lib/photos';
import GroupBadge from './GroupBadge.astro';
import TextLink from './TextLink.astro';

interface Props {
  item: UmkmData;
  group?: GroupData;
  eager?: boolean;
}

const { item, group, eager = false } = Astro.props;
const href = `/umkm/${item.groupId}/${item.slug}`;
---

<article class="umkm-card">
  <a class="umkm-card__image-link" href={href} aria-label={`Lihat ${item.name}`}>
    <img
      src={photoUrl(item.heroPhoto)}
      alt={item.heroPhoto ? `Foto profil ${item.name}` : `[DUMMY] Placeholder foto profil ${item.name}`}
      width="1200"
      height="900"
      loading={eager ? 'eager' : 'lazy'}
      decoding="async"
    />
  </a>
  <div class="umkm-card__body">
    <div class="umkm-card__badges">
      <GroupBadge kelompok={item.groupId} />
      <span class="umkm-card__category">{item.category}</span>
    </div>
    <div>
      <p class="umkm-card__village">{group?.village ?? item.groupId.toUpperCase()}</p>
      <h3><a href={href}>{item.name}</a></h3>
    </div>
    <p>{item.shortDescription}</p>
    <ul aria-label="Bentuk pendampingan">
      {item.assistance.slice(0, 3).map((label) => <li>{label}</li>)}
    </ul>
    <TextLink href={href}>Lihat profil UMKM</TextLink>
  </div>
</article>

<style>
  .umkm-card {
    display: grid;
    min-width: 0;
    overflow: hidden;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-surface);
    box-shadow: var(--shadow-sm);
    transition: box-shadow var(--transition-fast), transform var(--transition-fast);
  }

  .umkm-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-3px);
  }

  .umkm-card__image-link {
    overflow: hidden;
    background: var(--color-surface-soft);
  }

  img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    transition: transform var(--transition-fast);
  }

  .umkm-card:hover img {
    transform: scale(1.025);
  }

  .umkm-card__body {
    display: grid;
    padding: var(--space-5);
    align-content: start;
    gap: var(--space-3);
  }

  .umkm-card__badges {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
  }

  .umkm-card__category {
    color: var(--color-text-muted);
    font-size: var(--font-size-xs);
    font-weight: 750;
  }

  .umkm-card__village {
    color: var(--color-text-muted);
    font-size: var(--font-size-xs);
    font-weight: 700;
  }

  h3 {
    margin-top: var(--space-1);
    font-size: var(--font-size-xl);
  }

  h3 a {
    text-decoration: none;
  }

  h3 a:hover {
    color: #2f6f9d;
  }

  .umkm-card__body > p {
    color: var(--color-text-muted);
  }

  ul {
    display: flex;
    margin: 0;
    padding: 0;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
  }

  li {
    padding: 0.22rem 0.62rem;
    border-radius: var(--radius-pill);
    color: #2f6f9d;
    background: var(--color-primary-soft);
    font-size: var(--font-size-xs);
    font-weight: 700;
  }
</style>
