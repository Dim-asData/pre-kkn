---
import type { ContentStatus, KelompokId, ProgramCategory } from '../data/types';
import { CATEGORY_LABELS, formatDate } from '../data/format';
import { photoUrl } from '../lib/photos';
import Breadcrumb from './Breadcrumb.astro';
import GroupBadge from './GroupBadge.astro';
import StatusBadge from './StatusBadge.astro';

interface Props {
  title: string;
  description: string;
  kelompok: KelompokId;
  category: ProgramCategory;
  status: ContentStatus;
  plannedDate: string | null;
  actualDate: string | null;
  location: string;
  image?: string | null;
  imageAlt?: string | null;
}

const {
  title,
  description,
  kelompok,
  category,
  status,
  plannedDate,
  actualDate,
  location,
  image,
  imageAlt,
} = Astro.props;
const displayDate = formatDate(actualDate ?? plannedDate);
const dateLabel = actualDate ? 'Dilaksanakan' : plannedDate ? 'Direncanakan' : 'Tanggal';
const usesPlaceholder = !image;
---

<header class="article-header">
  <div class="container">
    <Breadcrumb
      items={[
        { label: 'Beranda', href: '/' },
        { label: 'Kegiatan', href: '/kegiatan' },
        { label: title },
      ]}
    />
    <div class="article-header__copy">
      <div class="article-header__badges">
        <GroupBadge kelompok={kelompok} showName />
        <span class="article-header__category">{CATEGORY_LABELS[category]}</span>
        <StatusBadge status={status} />
      </div>
      <h1>{title}</h1>
      <p class="article-header__description">{description}</p>
      <dl>
        <div>
          <dt>{dateLabel}</dt>
          <dd>{displayDate ?? 'Belum ditentukan'}</dd>
        </div>
        <div>
          <dt>Lokasi</dt>
          <dd>{location}</dd>
        </div>
      </dl>
    </div>
    <div class="article-header__media">
      <img
        class="article-header__image"
        src={photoUrl(image)}
        alt={
          usesPlaceholder
            ? `[DUMMY] Placeholder gambar utama ${title}`
            : imageAlt || `Gambar utama ${title}`
        }
        width="1440"
        height="810"
        loading="eager"
        decoding="async"
      />
      {usesPlaceholder && <span>[DUMMY] Placeholder gambar rencana</span>}
    </div>
  </div>
</header>

<style>
  .article-header {
    padding-block: var(--space-5) clamp(var(--space-7), 8vw, var(--space-9));
    background:
      radial-gradient(circle at 90% 14%, rgb(124 185 232 / 19%), transparent 20rem),
      linear-gradient(180deg, rgb(255 255 255 / 62%), transparent);
  }

  .article-header__copy {
    display: grid;
    max-width: 52rem;
    margin-top: var(--space-6);
    gap: var(--space-4);
  }

  .article-header__badges {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
  }

  .article-header__category {
    display: inline-flex;
    min-height: 1.75rem;
    align-items: center;
    padding: 0.22rem 0.68rem;
    border-radius: var(--radius-pill);
    color: #2f6f9d;
    background: var(--color-primary-soft);
    font-size: var(--font-size-xs);
    font-weight: 800;
  }

  h1 {
    max-width: 18ch;
    font-size: var(--font-size-3xl);
    letter-spacing: -0.035em;
  }

  .article-header__description {
    max-width: 44rem;
    color: var(--color-text-muted);
    font-size: var(--font-size-lg);
  }

  dl {
    display: flex;
    margin: var(--space-2) 0 0;
    flex-wrap: wrap;
    gap: var(--space-4) var(--space-7);
  }

  dl div {
    display: grid;
    gap: var(--space-1);
  }

  dt {
    color: var(--color-text-muted);
    font-size: var(--font-size-xs);
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  dd {
    margin: 0;
    font-size: var(--font-size-sm);
    font-weight: 700;
  }

  .article-header__media {
    position: relative;
    margin-top: var(--space-7);
  }

  .article-header__image {
    width: 100%;
    aspect-ratio: 16 / 9;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    object-fit: cover;
    background: var(--color-surface-soft);
    box-shadow: var(--shadow-sm);
  }

  .article-header__media > span {
    position: absolute;
    right: var(--space-4);
    bottom: var(--space-4);
    padding: 0.3rem 0.72rem;
    border-radius: var(--radius-pill);
    color: var(--color-surface);
    background: rgb(30 42 48 / 84%);
    font-size: var(--font-size-xs);
    font-weight: 800;
  }
</style>
