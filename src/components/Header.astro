---
interface Props {
  pathname?: string;
}

const { pathname = '/' } = Astro.props;
const navigation = [
  { label: 'Beranda', href: '/' },
  { label: 'Kegiatan', href: '/kegiatan' },
  { label: 'UMKM', href: '/umkm' },
  { label: 'Galeri', href: '/galeri' },
];

const isActive = (href: string) =>
  href === '/' ? pathname === href : pathname === href || pathname.startsWith(`${href}/`);
---

<header class="site-header" data-site-header>
  <div class="header-inner container">
    <a class="brand" href="/" aria-label="Jejak KKN Pancalang, beranda">
      <span class="brand-mark" aria-hidden="true">
        <span class="brand-dot brand-dot--t1"></span>
        <span class="brand-dot brand-dot--t2"></span>
        <span class="brand-dot brand-dot--t3"></span>
      </span>
      <span class="brand-copy">
        <strong>Jejak KKN</strong>
        <span>Pancalang</span>
      </span>
    </a>

    <button
      class="menu-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="navigasi-utama"
      aria-label="Buka menu navigasi"
      data-menu-toggle
    >
      <span></span>
      <span></span>
      <span></span>
    </button>

    <nav class="main-navigation" id="navigasi-utama" aria-label="Navigasi utama" data-menu>
      <ul>
        {
          navigation.map(({ label, href }) => (
            <li>
              <a href={href} aria-current={isActive(href) ? 'page' : undefined}>
                {label}
              </a>
            </li>
          ))
        }
      </ul>
      <a class="header-cta" href="/kegiatan">Jelajahi kegiatan</a>
    </nav>
  </div>
</header>

<script>
  const closeMenu = (header: HTMLElement) => {
    const toggle = header.querySelector<HTMLButtonElement>('[data-menu-toggle]');
    const menu = header.querySelector<HTMLElement>('[data-menu]');
    if (!toggle || !menu) return;

    toggle.setAttribute('aria-expanded', 'false');
    toggle.setAttribute('aria-label', 'Buka menu navigasi');
    menu.classList.remove('is-open');
  };

  document.querySelectorAll<HTMLElement>('[data-site-header]').forEach((header) => {
    const toggle = header.querySelector<HTMLButtonElement>('[data-menu-toggle]');
    const menu = header.querySelector<HTMLElement>('[data-menu]');
    if (!toggle || !menu) return;

    toggle.addEventListener('click', () => {
      const willOpen = toggle.getAttribute('aria-expanded') !== 'true';
      toggle.setAttribute('aria-expanded', String(willOpen));
      toggle.setAttribute('aria-label', willOpen ? 'Tutup menu navigasi' : 'Buka menu navigasi');
      menu.classList.toggle('is-open', willOpen);
    });

    menu.querySelectorAll('a').forEach((link) => link.addEventListener('click', () => closeMenu(header)));
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') {
      document.querySelectorAll<HTMLElement>('[data-site-header]').forEach(closeMenu);
    }
  });
</script>

<style>
  .site-header {
    position: relative;
    z-index: 20;
    border-bottom: 1px solid rgb(221 217 207 / 72%);
    background: rgb(250 249 245 / 88%);
    backdrop-filter: blur(14px);
  }

  .header-inner {
    position: relative;
    display: flex;
    min-height: 4.75rem;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .brand {
    display: inline-flex;
    min-height: 2.75rem;
    align-items: center;
    gap: var(--space-3);
    text-decoration: none;
  }

  .brand-mark {
    position: relative;
    display: grid;
    width: 2.625rem;
    height: 2.625rem;
    place-items: center;
    border-radius: 48% 52% 45% 55% / 56% 46% 54% 44%;
    background: var(--color-primary-soft);
    transform: rotate(-5deg);
  }

  .brand-dot {
    position: absolute;
    width: 0.66rem;
    height: 0.66rem;
    border: 2px solid var(--color-surface);
    border-radius: 50%;
    box-shadow: 0 2px 6px rgb(30 42 48 / 14%);
  }

  .brand-dot--t1 {
    top: 0.62rem;
    left: 0.66rem;
    background: var(--color-t1);
  }

  .brand-dot--t2 {
    top: 0.64rem;
    right: 0.59rem;
    background: var(--color-t2);
  }

  .brand-dot--t3 {
    bottom: 0.55rem;
    left: 1rem;
    background: var(--color-t3);
  }

  .brand-copy {
    display: grid;
    color: var(--color-text-muted);
    font-size: 0.67rem;
    letter-spacing: 0.11em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .brand-copy strong {
    color: var(--color-dark);
    font-family: var(--font-heading);
    font-size: 1.05rem;
    letter-spacing: -0.02em;
    text-transform: none;
  }

  .menu-toggle {
    display: grid;
    width: 2.75rem;
    height: 2.75rem;
    padding: 0.7rem;
    place-content: center;
    gap: 0.28rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    color: var(--color-dark);
    background: var(--color-surface);
    cursor: pointer;
  }

  .menu-toggle span {
    width: 1.2rem;
    height: 2px;
    border-radius: var(--radius-pill);
    background: currentColor;
    transition: transform var(--transition-fast), opacity var(--transition-fast);
  }

  .menu-toggle[aria-expanded='true'] span:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }

  .menu-toggle[aria-expanded='true'] span:nth-child(2) {
    opacity: 0;
  }

  .menu-toggle[aria-expanded='true'] span:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  .main-navigation {
    position: absolute;
    top: calc(100% + var(--space-2));
    right: var(--gutter);
    left: var(--gutter);
    display: none;
    padding: var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-surface);
    box-shadow: var(--shadow-md);
  }

  .main-navigation.is-open {
    display: grid;
    gap: var(--space-4);
  }

  .main-navigation ul {
    display: grid;
    margin: 0;
    padding: 0;
    gap: var(--space-1);
    list-style: none;
  }

  .main-navigation li,
  .main-navigation a {
    min-width: 0;
  }

  .main-navigation ul a {
    display: flex;
    min-height: 2.75rem;
    align-items: center;
    padding-inline: var(--space-3);
    border-radius: var(--radius-sm);
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
    font-weight: 650;
    text-decoration: none;
  }

  .main-navigation ul a:hover,
  .main-navigation ul a[aria-current='page'] {
    color: var(--color-dark);
    background: var(--color-primary-soft);
  }

  .header-cta {
    display: inline-flex;
    min-height: 2.75rem;
    align-items: center;
    justify-content: center;
    padding-inline: var(--space-4);
    border-radius: var(--radius-pill);
    color: var(--color-dark);
    background: var(--color-primary);
    font-size: var(--font-size-sm);
    font-weight: 750;
    text-decoration: none;
    transition: background var(--transition-fast), transform var(--transition-fast);
  }

  .header-cta:hover {
    background: #91c7ef;
    transform: translateY(-1px);
  }

  @media (min-width: 56rem) {
    .header-inner {
      min-height: 5.25rem;
    }

    .menu-toggle {
      display: none;
    }

    .main-navigation,
    .main-navigation.is-open {
      position: static;
      display: flex;
      padding: 0;
      align-items: center;
      gap: var(--space-5);
      border: 0;
      background: transparent;
      box-shadow: none;
    }

    .main-navigation ul {
      display: flex;
      align-items: center;
      gap: var(--space-1);
    }

    .main-navigation ul a {
      padding-inline: var(--space-3);
    }
  }
</style>
