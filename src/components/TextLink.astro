---
interface Props {
  href: string;
  ariaLabel?: string;
}

const { href, ariaLabel } = Astro.props;
---

<a class="text-link" {href} aria-label={ariaLabel}>
  <span><slot /></span>
  <svg viewBox="0 0 20 20" aria-hidden="true">
    <path d="M4.2 10h11.6m-4.4-4.4 4.4 4.4-4.4 4.4" />
  </svg>
</a>

<style>
  .text-link {
    display: inline-flex;
    min-height: 2.75rem;
    width: fit-content;
    align-items: center;
    gap: var(--space-2);
    color: #2f6f9d;
    font-size: var(--font-size-sm);
    font-weight: 750;
    text-decoration: none;
  }

  .text-link span {
    border-bottom: 1px solid currentColor;
  }

  .text-link:hover svg {
    transform: translateX(3px);
  }

  svg {
    width: 1.1rem;
    height: 1.1rem;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.8;
    transition: transform var(--transition-fast);
  }
</style>
