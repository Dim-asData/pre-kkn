---
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav class="breadcrumb" aria-label="Breadcrumb">
  <ol>
    {
      items.map((item, index) => {
        const isLast = index === items.length - 1;
        return (
          <li>
            {item.href && !isLast ? (
              <a href={item.href}>{item.label}</a>
            ) : (
              <span aria-current={isLast ? 'page' : undefined}>{item.label}</span>
            )}
            {!isLast && <span class="separator" aria-hidden="true">/</span>}
          </li>
        );
      })
    }
  </ol>
</nav>

<style>
  ol {
    display: flex;
    margin: 0;
    padding: 0;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
    list-style: none;
  }

  li {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
  }

  a {
    display: inline-flex;
    min-height: 2.75rem;
    align-items: center;
    color: #2f6f9d;
  }

  [aria-current='page'] {
    color: var(--color-text);
    font-weight: 650;
  }

  .separator {
    color: var(--color-border);
  }
</style>
