---
interface Props {
  number?: string | null;
  label?: string;
}

const { number, label = 'Hubungi melalui WhatsApp' } = Astro.props;
const href = number ? `https://wa.me/${number}` : null;
---

{
  href ? (
    <a class="whatsapp-button" href={href} target="_blank" rel="noreferrer">
      <span aria-hidden="true">WA</span>
      {label}
    </a>
  ) : (
    <span class="whatsapp-button whatsapp-button--disabled" aria-disabled="true">
      <span aria-hidden="true">WA</span>
      Kontak belum tersedia
    </span>
  )
}

<style>
  .whatsapp-button {
    display: inline-flex;
    min-height: 2.75rem;
    width: fit-content;
    padding: 0.62rem 1rem;
    align-items: center;
    gap: var(--space-2);
    border: 1px solid #267a4a;
    border-radius: var(--radius-pill);
    color: #1f633c;
    background: #e9f7ee;
    font-size: var(--font-size-sm);
    font-weight: 800;
    text-decoration: none;
  }

  .whatsapp-button > span {
    display: grid;
    width: 1.8rem;
    height: 1.8rem;
    place-items: center;
    border-radius: 50%;
    color: white;
    background: #267a4a;
    font-size: 0.62rem;
  }

  .whatsapp-button--disabled {
    border-color: var(--color-border);
    color: var(--color-text-muted);
    background: var(--color-surface-soft);
  }

  .whatsapp-button--disabled > span {
    background: var(--color-text-muted);
  }
</style>
