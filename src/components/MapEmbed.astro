---
interface Props {
  embedUrl?: string | null;
  address?: string | null;
  label: string;
}

const { embedUrl, address, label } = Astro.props;
const searchUrl = address
  ? `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(address)}`
  : null;
---

<section class="map-embed" aria-label={`Lokasi ${label}`}>
  {
    embedUrl ? (
      <iframe
        src={embedUrl}
        title={`Peta ${label}`}
        width="600"
        height="450"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
      />
    ) : (
      <div class="map-embed__fallback">
        <span aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path d="M12 21s6-5.3 6-11a6 6 0 1 0-12 0c0 5.7 6 11 6 11Z"></path>
            <circle cx="12" cy="10" r="2"></circle>
          </svg>
        </span>
        <div>
          <h3>Peta belum tersedia</h3>
          <p>{address ?? 'Alamat belum dicantumkan.'}</p>
          {searchUrl && (
            <a href={searchUrl} target="_blank" rel="noreferrer">
              Cari alamat di Google Maps
            </a>
          )}
        </div>
      </div>
    )
  }
</section>

<style>
  .map-embed {
    overflow: hidden;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-surface);
  }

  iframe {
    display: block;
    width: 100%;
    min-height: 21rem;
    border: 0;
  }

  .map-embed__fallback {
    display: grid;
    min-height: 15rem;
    padding: var(--space-5);
    place-content: center;
    grid-template-columns: auto minmax(0, 1fr);
    gap: var(--space-3);
    background:
      linear-gradient(rgb(250 249 245 / 86%), rgb(250 249 245 / 86%)),
      repeating-linear-gradient(
        45deg,
        var(--color-border) 0,
        var(--color-border) 1px,
        transparent 1px,
        transparent 14px
      );
  }

  .map-embed__fallback > span {
    display: grid;
    width: 2.75rem;
    height: 2.75rem;
    place-items: center;
    border-radius: 50%;
    color: #2f6f9d;
    background: var(--color-primary-soft);
  }

  svg {
    width: 1.4rem;
    height: 1.4rem;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.7;
  }

  h3 {
    font-size: var(--font-size-lg);
  }

  p {
    margin-top: var(--space-1);
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
  }

  a {
    display: inline-flex;
    min-height: 2.75rem;
    margin-top: var(--space-2);
    align-items: center;
    color: #2f6f9d;
    font-size: var(--font-size-sm);
    font-weight: 750;
  }
</style>
