---
import type { KelompokId } from '../data/types';

interface Props {
  kelompok: KelompokId;
  showName?: boolean;
}

const { kelompok, showName = false } = Astro.props;
const labels: Record<KelompokId, string> = {
  t1: 'T1',
  t2: 'T2',
  t3: 'T3',
};
const villages: Record<KelompokId, string> = {
  t1: 'Sumbakeling',
  t2: 'Silebu',
  t3: 'Pancalang',
};
---

<span class:list={['group-badge', `group-badge--${kelompok}`]}>
  <span class="group-badge__dot" aria-hidden="true"></span>
  {labels[kelompok]}{showName && <span>&nbsp;· {villages[kelompok]}</span>}
</span>

<style>
  .group-badge {
    display: inline-flex;
    min-height: 1.75rem;
    width: fit-content;
    align-items: center;
    padding: 0.22rem 0.68rem;
    gap: 0.38rem;
    border: 1px solid currentColor;
    border-radius: var(--radius-pill);
    font-size: var(--font-size-xs);
    font-weight: 800;
    line-height: 1.2;
  }

  .group-badge__dot {
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 50%;
    background: currentColor;
  }

  .group-badge--t1 {
    color: var(--color-t1-dark);
    background: var(--color-t1-soft);
  }

  .group-badge--t2 {
    color: var(--color-t2);
    background: var(--color-t2-soft);
  }

  .group-badge--t3 {
    color: var(--color-t3-dark);
    background: var(--color-t3-soft);
  }
</style>
